rules_version = '2';

// Firestore security rules for the FT50 Paper Browser accounts.
// Every signed-in user can read and write ONLY their own data subtree, so each
// person's saved papers, notes, lists and tags are private to them. Deploy with:
//   firebase deploy --only firestore:rules
// (or paste into Firebase console -> Firestore Database -> Rules -> Publish).

service cloud.firestore {
  match /databases/{database}/documents {

    match /users/{userId}/{document=**} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }

  }
}
