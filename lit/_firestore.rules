rules_version = '2';

// Firestore security rules for The Lit paper-browser accounts.
// Every signed-in user can read and write ONLY their own data subtree, so each
// person's saved papers, notes, lists, tags and e-mail alerts are private to
// them. The recursive wildcard below already covers the alerts subcollection
// (users/{uid}/alerts/*) and the one-off test-e-mail queue
// (users/{uid}/testEmails/*), so no extra rule is needed for E-mail alerts. The
// alert mailer (see _EMAIL-ALERTS-SETUP.md) reads both server-side with the
// Admin SDK, which bypasses these rules. Deploy with:
//   firebase deploy --only firestore:rules
// (or paste into Firebase console -> Firestore Database -> Rules -> Publish).

service cloud.firestore {
  match /databases/{database}/documents {

    match /users/{userId}/{document=**} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }

    // Public registered-users tally (counted by lit/analytics/). Each account
    // owns exactly ONE doc here, keyed by its uid and holding only a coarse
    // "last seen" timestamp `t` — no e-mail, name or any private data. It is
    // publicly readable so the static analytics page can COUNT the collection
    // (the number of docs = number of registered users); each user may only
    // create/update their OWN doc, the payload is pinned to just `t`, and nobody
    // can delete. No user's private subtree above is exposed by this.
    match /registeredUsers/{userId} {
      allow read: if true;
      allow create, update: if request.auth != null
                            && request.auth.uid == userId
                            && request.resource.data.keys().hasOnly(['t']);
      allow delete: if false;
    }

    // Duplicate-account detection (same person, two accounts). Each signed-in
    // session claims its identity keys — "orcid:<iD>" and "email:<sha256 of
    // the lowercased address>" — mapping the key to the owning uid. A later
    // sign-in whose key is already claimed by a DIFFERENT uid is a duplicate,
    // and the page offers the merge flow. Signed-in read only (conflict
    // checks; keys are an opaque uid mapping, e-mails only ever hashed);
    // create/update must claim your own uid; never deletable.
    match /accountKeys/{key} {
      allow read: if request.auth != null;
      allow create, update: if request.auth != null
                            && request.resource.data.keys().hasOnly(['uid', 't'])
                            && request.resource.data.uid == request.auth.uid;
      allow delete: if false;
    }

    // Public shared lists. A signed-in user can make one of their saved-paper
    // lists public (main page → My Library → a list's 🔗 Share → "Make public").
    // We store a denormalized, read-only snapshot here — keyed by an unguessable
    // random share id — because a viewer cannot read the owner's private
    // users/{uid}/** subtree. It carries ONLY bibliographic fields (each paper's
    // title/authors/year/DOI), never the owner's private note or tags. Anyone
    // (even signed-out) may READ a shared list by its id; only the owner may
    // create/update/delete their own, and the payload is bounded so it can't be
    // abused as free public storage. Turning the list private again deletes the
    // doc, so the old link stops resolving.
    match /publicLists/{shareId} {
      allow read: if true;
      allow create: if request.auth != null
                    && request.auth.uid == request.resource.data.ownerUid
                    && request.resource.data.keys().hasOnly(
                         ['ownerUid','owner','name','count','papers','createdAt','updatedAt'])
                    && request.resource.data.name is string
                    && request.resource.data.name.size() <= 200
                    && request.resource.data.papers is list
                    && request.resource.data.papers.size() <= 5000;
      allow update: if request.auth != null
                    && request.auth.uid == resource.data.ownerUid
                    && request.auth.uid == request.resource.data.ownerUid
                    && request.resource.data.keys().hasOnly(
                         ['ownerUid','owner','name','count','papers','createdAt','updatedAt'])
                    && request.resource.data.name is string
                    && request.resource.data.name.size() <= 200
                    && request.resource.data.papers is list
                    && request.resource.data.papers.size() <= 5000;
      allow delete: if request.auth != null && request.auth.uid == resource.data.ownerUid;
    }

    // Feedback inbox (written by the standalone /lit/feedback/ page). Anyone may
    // CREATE a bounded feedback document (a short message, its generated ticket
    // number and a few client-compressed screenshots as data URLs). It is NOT
    // publicly readable: only the site maintainer — signed in as the admin
    // account — may READ the inbox and mark a submission complete (update) or
    // DELETE it. That is what powers the admin dashboard shown on the Feedback
    // page for that one account (kstouras@gmail.com). The server mailers and the
    // GitHub logger use the Admin SDK, which bypasses these rules. Bounds below
    // keep the collection from being abused as free public storage.
    function isFeedbackAdmin() {
      return request.auth != null
             && request.auth.token.email == 'kstouras@gmail.com'
             && request.auth.token.email_verified == true;
    }
    match /feedback/{docId} {
      allow create: if request.resource.data.keys().hasOnly(
                         ['text','images','name','email','uid','ticket','page','url','ua','forwarded','status','createdAt'])
                    && request.resource.data.text is string
                    && request.resource.data.text.size() <= 20000
                    && (!('images' in request.resource.data)
                        || (request.resource.data.images is list
                            && request.resource.data.images.size() <= 5))
                    && request.resource.data.forwarded == false;
      allow read:           if isFeedbackAdmin();
      allow update, delete: if isFeedbackAdmin();
    }

    // Paper submissions (written by the "Suggest a working paper" section of the
    // /lit/feedback/ page). A SIGNED-IN user may CREATE one bounded submission
    // claiming their own uid, with `status` pinned to 'pending' on create (so the
    // client can't pre-mark it added/rejected — only the server ingest does that).
    // The submitter may READ their own submissions (to see the outcome); only the
    // maintainer admin may read the whole queue and update/delete it. The server
    // ingest (lit/_scraper-workingpapers/ingest-submissions.mjs) uses the Admin
    // SDK, which bypasses these rules. Bounds keep it from being abused as storage.
    match /paperSubmissions/{docId} {
      allow create: if request.auth != null
                    && request.auth.uid == request.resource.data.uid
                    && request.resource.data.keys().hasOnly(
                         ['uid','email','name','url','title','authors','note','ticket','status','createdAt'])
                    && request.resource.data.url is string
                    && request.resource.data.url.size() <= 2000
                    && (!('email' in request.resource.data)
                        || (request.resource.data.email is string && request.resource.data.email.size() <= 320))
                    && (!('name' in request.resource.data)
                        || (request.resource.data.name is string && request.resource.data.name.size() <= 200))
                    && (!('title' in request.resource.data)
                        || (request.resource.data.title is string && request.resource.data.title.size() <= 500))
                    && (!('authors' in request.resource.data)
                        || (request.resource.data.authors is string && request.resource.data.authors.size() <= 2000))
                    && (!('note' in request.resource.data)
                        || (request.resource.data.note is string && request.resource.data.note.size() <= 5000))
                    && request.resource.data.status == 'pending';
      allow read:           if isFeedbackAdmin()
                            || (request.auth != null && request.auth.uid == resource.data.uid);
      allow update, delete: if isFeedbackAdmin();
    }

  }
}
