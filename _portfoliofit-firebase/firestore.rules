rules_version = '2';

// PortfolioFit for Managers — Firestore security rules.
//
// Model:
//   config/app            editable content + registration/survey questions + settings   (admin write, signed-in read)
//   puzzleSets/{id}        approved puzzle library                                        (admin write, signed-in read)
//   counters/{id}          sequential label counter, only Cloud Functions touch it
//   participants/{uid}     one doc per participant (created by registerParticipant fn)
//     events/{id}          one doc per logged action (place/move/rotate/remove/calc/note/...)
//     rounds/{id}          per-round summary
//     survey/{id}          survey answers
//
// Admin is identified solely by the signed-in email admin@admin.com.

service cloud.firestore {
  match /databases/{database}/documents {

    function signedIn()      { return request.auth != null; }
    function isAdmin()       { return signedIn() && request.auth.token.email == 'admin@admin.com'; }
    function isOwner(uid)    { return signedIn() && request.auth.uid == uid; }

    // ---- App content / configuration (admin-managed CMS) ----
    match /config/{docId} {
      allow read:  if signedIn();
      allow write: if isAdmin();
    }

    // ---- Approved puzzle library ----
    match /puzzleSets/{puzzleId} {
      allow read:  if signedIn();
      allow write: if isAdmin();
    }

    // ---- Sequential-label counter: only Cloud Functions (admin SDK) may write ----
    match /counters/{counterId} {
      allow read:  if isAdmin();
      allow write: if false;
    }

    // ---- Participants ----
    match /participants/{uid} {
      allow read:   if isOwner(uid) || isAdmin();
      allow create: if isOwner(uid);                 // primary path is the registerParticipant function (admin SDK)
      allow update: if isOwner(uid) || isAdmin();
      allow delete: if isAdmin();

      // One document per logged gameplay action. Append-only for participants.
      match /events/{eventId} {
        allow read:   if isOwner(uid) || isAdmin();
        allow create: if isOwner(uid);
        allow update, delete: if false;
      }

      // Per-round summaries.
      match /rounds/{roundId} {
        allow read:          if isOwner(uid) || isAdmin();
        allow create, update: if isOwner(uid);
        allow delete:        if isAdmin();
      }

      // Survey answers (also written by the submitSurvey function, which bypasses rules).
      match /survey/{docId} {
        allow read:          if isOwner(uid) || isAdmin();
        allow create, update: if isOwner(uid);
        allow delete:        if false;
      }
    }
  }
}
